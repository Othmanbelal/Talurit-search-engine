# Deployment template for:
# C:\Users\tools\Desktop\ToolInventory\app
#
# Copy this file to ".env" on the new computer:
# Copy-Item .env.example2 .env
#
# Replace every value beginning with REPLACE_ before starting Docker.

NODE_ENV=production
PORT=4000

# Replace this IP with the new computer's IPv4 address from "ipconfig".
CLIENT_URL=http://REPLACE_WITH_NEW_PC_IP:5173
APP_PUBLIC_URL=http://REPLACE_WITH_NEW_PC_IP:5173

# Use one URL-safe random password containing letters and numbers.
# The same value must appear in POSTGRES_PASSWORD and DATABASE_URL.
POSTGRES_DB=tool_inventory
POSTGRES_USER=tool_user
POSTGRES_PASSWORD=REPLACE_WITH_URL_SAFE_DATABASE_PASSWORD
POSTGRES_PORT=5432
SERVER_PORT=4000
CLIENT_PORT=5173
DATABASE_URL=postgresql://tool_user:REPLACE_WITH_URL_SAFE_DATABASE_PASSWORD@localhost:5432/tool_inventory

# For restoring the current .tibackup, initially copy SESSION_SECRET from
# the old computer. Do not create a new value until after the restore.
SESSION_SECRET=REPLACE_WITH_SESSION_SECRET_FROM_OLD_COMPUTER
COOKIE_NAME=tool_inventory_session
SESSION_DAYS=7
PASSWORD_RESET_MINUTES=30

# This administrator is created after restoring and cleaning the old data.
ADMIN_EMAIL=REPLACE_WITH_NEW_ADMIN_EMAIL
ADMIN_PASSWORD=REPLACE_WITH_LONG_NEW_ADMIN_PASSWORD
ADMIN_NAME=REPLACE_WITH_ADMIN_NAME

# Email is required for invitations and forgot-password links.
# These values may be left blank until company SMTP details are available.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_SECURE=false
ADMIN_SUMMARY_EMAIL=REPLACE_WITH_NEW_ADMIN_EMAIL

# Persistent folders already created beside the app folder.
BACKUP_DIR=./backups
BACKUP_HOST_DIR=C:/Users/tools/Desktop/ToolInventory/backups
UPLOAD_DIR=./uploads
UPLOAD_HOST_DIR=C:/Users/tools/Desktop/ToolInventory/uploads

# Store item, QR, and profile images on this computer.
STORAGE_DRIVER=local

# Leave these blank when STORAGE_DRIVER=local.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=tool-inventory-uploads
SUPABASE_SIGNED_URL_SECONDS=3600

WEEKLY_SUMMARY_CRON=0 16 * * 5

# Docker/Nginx uses same-origin /api requests, so this remains blank.
VITE_API_URL=
