NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:5173
APP_PUBLIC_URL=http://localhost:5173

DATABASE_URL=postgresql://tool_user:tool_password@localhost:5432/tool_inventory
# Production example for Supabase server-based deployments:
# DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres?sslmode=require

SESSION_SECRET=change_me_long_random_secret
COOKIE_NAME=tool_inventory_session
SESSION_DAYS=7

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!
ADMIN_NAME=System Admin

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_SECURE=false
ADMIN_SUMMARY_EMAIL=

BACKUP_DIR=./backups
UPLOAD_DIR=./uploads
WEEKLY_SUMMARY_CRON=0 16 * * 5
DAILY_BACKUP_CRON=0 2 * * *

# Frontend deploy variable for Vercel. In production this should be your Render API URL.
VITE_API_URL=http://localhost:4000
