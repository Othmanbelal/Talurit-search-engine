NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:5173
APP_PUBLIC_URL=http://localhost:5173

# Docker PostgreSQL. Use a URL-safe random password and keep both values in sync.
POSTGRES_DB=tool_inventory
POSTGRES_USER=tool_user
POSTGRES_PASSWORD=REPLACE_WITH_URL_SAFE_RANDOM_PASSWORD
POSTGRES_PORT=5432
SERVER_PORT=4000
CLIENT_PORT=5173
DATABASE_URL=postgresql://tool_user:REPLACE_WITH_URL_SAFE_RANDOM_PASSWORD@localhost:5432/tool_inventory

# Production example for Supabase:
# DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require

SESSION_SECRET=REPLACE_WITH_AT_LEAST_32_RANDOM_CHARACTERS
COOKIE_NAME=tool_inventory_session
SESSION_DAYS=7
PASSWORD_RESET_MINUTES=30

ADMIN_EMAIL=your-admin@company.com
ADMIN_PASSWORD=REPLACE_WITH_A_LONG_RANDOM_PASSWORD
ADMIN_NAME=Your Administrator

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_SECURE=false
ADMIN_SUMMARY_EMAIL=

BACKUP_DIR=./backups
# Docker host folder mounted into /app/backups. This may be a local, OneDrive,
# SharePoint-synced, or NAS-mounted folder visible to the host machine.
BACKUP_HOST_DIR=./backups
UPLOAD_DIR=./uploads
UPLOAD_HOST_DIR=./uploads

# Required when item, QR, or profile images use Supabase Storage.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=tool-inventory-uploads
SUPABASE_SIGNED_URL_SECONDS=3600

WEEKLY_SUMMARY_CRON=0 16 * * 5

# Frontend deploy variable for Vercel. In production this should be your Render API URL.
VITE_API_URL=http://localhost:4000
